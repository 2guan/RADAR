# 文件：.gitignore
# 用途：声明仓库忽略的依赖、构建产物、运行数据与本地工具配置。
# 作者：hengguan

# 依赖
node_modules/
# 构建产物
dist/
web/dist/
# 运行时数据（挂载目录）
data/*.db
data/*.db-shm
data/*.db-wal
attachments/*
!attachments/.gitkeep
# 环境与日志
.env
*.log
.DS_Store

# 本地工具/代理配置（不入库）
.assistant-tools/
.impeccable/
.claude/

# 操作手册图片仅用于本地文档维护，不纳入版本控制
docs/manuals/screenshots/
