{
  "name": "radar-server",
  "version": "1.0.0",
  "description": "RADAR 日常需求研发流程管理 - 后端服务",
  "author": "hengguan",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test",
    "migrate:db": "node scripts/sqlite-to-tdsql.js",
    "migrate:tdsql": "node scripts/sqlite-to-tdsql.js --direction sqlite-to-tdsql",
    "migrate:sqlite": "node scripts/sqlite-to-tdsql.js --direction tdsql-to-sqlite",
    "migrate:tdsql-to-tdsql": "node scripts/sqlite-to-tdsql.js --direction tdsql-to-tdsql",
    "dump:tdsql": "node scripts/tdsql-dump.js",
    "restore:tdsql": "node scripts/tdsql-restore.js"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^9.1.3",
    "docx": "^9.7.1",
    "exceljs": "^3.10.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "jszip": "^3.10.1",
    "mysql2": "^3.22.5"
  }
}
