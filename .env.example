# =============================================================================
# RADAR 环境变量示例
# -----------------------------------------------------------------------------
# 作者：hengguan
# 用途：集中列出 RADAR 运行、数据库切换、迁移脚本和 Docker 部署可用的环境变量。
# -----------------------------------------------------------------------------
# 使用方式：
# 1. 复制本文件为 .env
# 2. 按部署环境修改各项值
# 3. 生产环境务必替换所有密钥和初始密码
# =============================================================================


# =============================================================================
# 1. 基础运行配置
# =============================================================================

# 运行环境：production 表示生产模式；development 可用于本地调试
NODE_ENV=production

# 后端监听地址：Docker/服务器部署通常使用 0.0.0.0
HOST=0.0.0.0

# 后端容器/进程内监听端口
PORT=3000

# Docker Compose 暴露到宿主机的访问端口
RADAR_HTTP_PORT=3510

# Docker Compose 容器名称
RADAR_CONTAINER_NAME=radar

# Docker 构建基础镜像。国内服务器如无法访问 Docker Hub，可使用镜像加速地址。
NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine

# Docker 构建时 npm 依赖下载源。国内服务器推荐使用 npmmirror。
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com


# =============================================================================
# 2. JWT 与初始管理员
# =============================================================================

# JWT 签名密钥：生产环境必须改为随机长字符串
JWT_SECRET=please-change-this-secret-in-production

# JWT 登录有效期，例如 12h、7d
JWT_EXPIRES_IN=12h

# 初始超级管理员登录名：仅首次初始化数据库时使用
ADMIN_PHONE=admin

# 初始超级管理员显示名称：仅首次初始化数据库时使用
ADMIN_NAME=超级管理员

# 初始超级管理员密码：必须显式配置，系统不会提供默认密码
ADMIN_PASSWORD=please-change-this-admin-password


# =============================================================================
# 3. 数据库、附件与静态资源路径
# =============================================================================

# 数据库类型：sqlite 或 tdsql。tdsql 表示 TDSQL MySQL 兼容版
DB_CLIENT=sqlite

# SQLite 数据库文件路径；仅 DB_CLIENT=sqlite 时用于运行；迁移工具也可读取该文件
DB_FILE=./data/radar.db

# TDSQL MySQL 兼容版连接配置；仅 DB_CLIENT=tdsql 时用于运行
TDSQL_HOST=127.0.0.1
TDSQL_PORT=3306
TDSQL_DATABASE=radar
TDSQL_USER=radar_app
TDSQL_PASSWORD=
TDSQL_SSL=false
TDSQL_CONNECTION_LIMIT=10
TDSQL_TIMEZONE=+08:00

# 附件存储目录；相对路径会按仓库根目录解析
ATTACHMENT_DIR=./attachments

# 前端构建产物目录；生产模式下由后端托管
WEB_DIST=./web/dist

# Docker Compose 宿主机数据库挂载目录
RADAR_DATA_DIR=./RADARdata/data

# Docker Compose 宿主机附件挂载目录
RADAR_ATTACHMENTS_DIR=./RADARdata/attachments


# =============================================================================
# 4. 外部 PAMS 问题系统
# =============================================================================

# PAMS 服务基础地址；留空时同步问题接口会提示“PAMS 接口未配置”
PAMS_BASE_URL=

# PAMS API Key；留空时同步问题接口会提示“PAMS 接口未配置”
PAMS_API_KEY=

# PAMS 请求超时时间，单位毫秒
PAMS_TIMEOUT=20000


# =============================================================================
# 5. CORS、CSP 与 CSRF
# =============================================================================

# 允许跨域访问的前端来源；多个来源用英文逗号分隔，生产环境建议显式配置
CORS_ORIGINS=

# CSP connect-src 白名单；多个来源用英文逗号分隔，self 会自动转换为 'self'
CSP_CONNECT_SRC=self

# 写操作请求头 X-Requested-By 的期望值；前后端必须保持一致
CSRF_HEADER_VALUE=RADAR


# =============================================================================
# 6. 上传、请求体、限流与压缩
# =============================================================================

# 单个附件最大字节数；默认 52428800 = 50MB
MAX_FILE_SIZE=52428800

# 允许上传的文件扩展名白名单；多个扩展名用英文逗号分隔
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.md,.csv,.zip,.rar,.7z,.png,.jpg,.jpeg,.gif,.bmp,.svg

# 非 multipart API 请求体最大字节数；默认 1048576 = 1MB
API_BODY_LIMIT=1048576

# 单 IP 每个限流窗口内最多请求数
RATE_LIMIT_MAX=600

# 限流窗口，例如 1 minute、30 seconds
RATE_LIMIT_WINDOW=1 minute

# 响应压缩阈值，低于该字节数不压缩
COMPRESSION_THRESHOLD=1024


# =============================================================================
# 7. 日志
# =============================================================================

# 后端日志级别：info 输出启动/迁移/初始化等普通信息；warn 仅输出警告与错误；error 仅输出错误；silent 关闭
LOG_LEVEL=info

# 是否输出每个 HTTP 请求的访问日志；生产环境建议 false，排查接口问题时可临时改为 true
REQUEST_LOGGING=false

# 前端浏览器控制台日志级别：info / warn / error / silent
VITE_LOG_LEVEL=warn


# =============================================================================
# 8. 验证码与电子签名
# =============================================================================

# 验证码有效期，单位毫秒；默认 300000 = 5 分钟
CAPTCHA_EXPIRES_MS=300000

# 单个验证码最多尝试次数
CAPTCHA_MAX_ATTEMPTS=3

# 验证码字符长度
CAPTCHA_CODE_LENGTH=4

# 过期验证码清理间隔，单位毫秒
CAPTCHA_CLEANUP_INTERVAL_MS=60000

# 单张电子签名图片最大字节数；默认 2097152 = 2MB
SIGNATURE_MAX_BYTES=2097152


# =============================================================================
# 9. 前端开发与请求配置
# =============================================================================

# Vite 开发服务器端口
VITE_DEV_PORT=5173

# Vite 开发代理目标；本地开发时 /api 会代理到该后端地址
VITE_API_PROXY_TARGET=http://localhost:3000

# 前端 Axios API 基础路径；同域部署通常使用 /api
VITE_API_BASE_URL=/api

# 前端请求超时时间，单位毫秒
VITE_API_TIMEOUT=30000

# 前端写操作请求头 X-Requested-By 的值；必须与 CSRF_HEADER_VALUE 保持一致
VITE_CSRF_HEADER_VALUE=RADAR

# Vite 构建产物 chunk 体积警告阈值，单位 KB
VITE_CHUNK_SIZE_WARNING_LIMIT=1500
