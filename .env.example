# RADAR 后端环境变量示例（复制为 .env 并按需修改）
# 服务端口
PORT=3000
# 运行环境
NODE_ENV=production
# JWT 密钥（生产环境务必修改为随机长字符串）
JWT_SECRET=please-change-this-secret-in-production
# JWT 有效期
JWT_EXPIRES_IN=12h
# 数据库文件路径
DB_FILE=./data/radar.db
# 附件存储目录
ATTACHMENT_DIR=./attachments
# 前端构建产物目录
WEB_DIST=./web/dist
# 初始超级管理员
ADMIN_PHONE=admin
ADMIN_PASSWORD=admin2026
# 附件最大字节数（默认 50MB）
MAX_FILE_SIZE=52428800
